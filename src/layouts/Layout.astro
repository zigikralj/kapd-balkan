---
import '../styles/global.css';
import { translations } from '../utils/translations.js';

interface Props {
	title?: string;
	description?: string;
	lang?: 'sr' | 'en';
}

const { 
	lang = 'sr',
	title = translations[lang].title, 
	description = translations[lang].description
} = Astro.props;

const t = translations[lang];
---

<!DOCTYPE html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={t.keywords} />
		<meta name="author" content={t.title} />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.kapd-balkan.rs/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(`${import.meta.env.BASE_URL}logo.png`, Astro.site).toString()} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://www.kapd-balkan.rs/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(`${import.meta.env.BASE_URL}logo.png`, Astro.site).toString()} />

		<link rel="icon" type="image/x-icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
		<link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />

		<!-- Google Fonts Integration -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Bitter:ital,wght@0,400;0,500;0,700;1,400;1,500;1,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body>
		<slot />
	</body>
</html>
