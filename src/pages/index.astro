---
import Layout from '../layouts/Layout.astro';

// Leaf particle configs (pre-defined for consistency across static builds)
const leaves = [
  { left: 8, delay: 0.2, duration: 9, size: 16 },
  { left: 22, delay: 2.1, duration: 12, size: 24 },
  { left: 38, delay: 4.3, duration: 10, size: 18 },
  { left: 52, delay: 0.8, duration: 13, size: 28 },
  { left: 68, delay: 5.2, duration: 8, size: 14 },
  { left: 82, delay: 3.1, duration: 11, size: 22 },
  { left: 94, delay: 1.4, duration: 14, size: 20 },
  { left: 15, delay: 6.2, duration: 11, size: 15 },
  { left: 30, delay: 0.1, duration: 9, size: 26 },
  { left: 45, delay: 3.4, duration: 12, size: 18 },
  { left: 60, delay: 2.3, duration: 9, size: 22 },
  { left: 75, delay: 6.7, duration: 13, size: 16 },
  { left: 88, delay: 4.6, duration: 10, size: 20 },
];

const aboutImages = [
  { id: "biblioteka_1", url: "/biblioteka_1.jpg", width: 800, height: 600, alt: "Едукативна радионица у библиотеци" },
  { id: "deca_2", url: "/deca_2.jpg", width: 918, height: 1386, alt: "Активности са децом на Гочу" },
  { id: "deca_3", url: "/deca_3.jpg", width: 960, height: 720, alt: "Теренски рад у заштићеном подручју" }
];

const collaborators = [
  { id: "srbijasume", url: "/Srbijasume.png", width: 194, height: 128, link: "https://srbijasume.rs/", caption: "ЈП Србијашуме" },
  { id: "VSI_KV", url: "/VSI_KV.jpg", width: 173, height: 44, link: "http://www.vsikv.com", caption: "Ветеринарски специјалистички институт Краљево" },
  { id: "NP_Djerdap", url: "/NP_Djerdap.svg", width: 158, height: 146, link: "https://npdjerdap.rs/", caption: 'Национални парк "Ђердап"' },
  { id: "biblioteka_kv", url: "/biblioteka_kv.jpg", width: 235, height: 55, link: "http://www.kv-biblio.org.rs", caption: 'Народна библиотека "Стефан Првовенчани" Краљево' },
  { id: "sumarska_kv", url: "/sumarska_kv.png", width: 238, height: 48, link: "http://www.sumarska.edu.rs", caption: "Шумарска школа Краљево" },
  { id: "poljoprivredna_kv", url: "/poljoprivredna_kv.png", width: 114, height: 131, link: "http://www.ratarica.edu.rs", caption: 'ПХШ "Др. Ђорђе Радић" Краљево' },
  { id: "pmf_kg", url: "/pmf_kg.gif", width: 283, height: 60, link: "https://ibe.pmf.kg.ac.rs/", caption: "Институт за биологију и екологију ПМФ Крагујевац" },
  { id: "sbd_stevan_jakovljevic", url: "/SBD_Stevan_Jakovljevic.png", width: 133, height: 134, link: "https://www.facebook.com/SBDKragujevac/?locale=sr_RS", caption: 'СБД "Стеван Јаковљевић"' },
  { id: "eid_mladen_karaman", url: "/eid_mladen_karaman.jpg", width: 123, height: 138, link: "https://www.facebook.com/eidmladenkaraman/?locale=sr_RS", caption: 'Еколошко истраживачко друштво "Младен Караман"' }
];
---

<Layout>
	<main class="page_main">
		<!-- Sticky Header Navigation -->
		<header>
			<a href="#o_nama">О нама</a>
			<a href="#natura_2000">Натура 2000</a>
			<a href="#saradnici">Сарадници</a>
			<a href="#kontakt">Контакт</a>
		</header>

		<!-- Nature-themed Hero Banner -->
		<div class="hero-container" id="heroBanner">
			<div class="hero-overlay"></div>
			
			<!-- Leaf Particles -->
			{leaves.map((leaf) => (
				<div 
					class="leaf" 
					style={`left: ${leaf.left}%; animation-delay: ${leaf.delay}s; animation-duration: ${leaf.duration}s; width: ${leaf.size}px; height: ${leaf.size}px;`}
				/>
			))}

			<!-- Glassmorphic Card containing branding -->
			<div class="glass-card">
				<div class="hero-logo-wrapper">
					<img 
						class="hero-logo" 
						src="/logo.png" 
						alt="КАПД Балкан Лого" 
						width="390" 
						height="184" 
					/>
				</div>
			</div>

			<!-- Bouncing Scroll Down Arrow -->
			<a href="#o_nama" class="scroll-indicator" aria-label="Скролујте до садржаја">
				<span class="scroll-text">Истражи</span>
				<svg class="scroll-arrow" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</a>
		</div>

		<!-- Main Content Container -->
		<div class="main-content-container">
			
			<!-- About Us Section -->
			<section id="o_nama">
				<div class="section-content">
					<h2>Краљевско академско природњачко друштво Балкан</h2>
					<p>
						Краљевско академско природњачко друштво Балкан основано је 23.12.2010. године. 
						Од свог оснивања чланови Друштва организују едукације ученика основних школа из 
						Србије у сарадњи са Народном библиотеком &quot;Стефан Првовенчани&quot; у Краљеву, 
						Дечијим одмаралиштем на Гочу, ПХШ &quot;Др. Ђорђе Радић&quot;, Шумарском школом у 
						Краљеву и осталим основним и средњим школама са територије града Краљева. 
						Укупно до сад је реализовано преко 40 радионица кроз које је прошло више од 2000 
						учесника, као и више од 20 теренских излета у заштићена подручја нашег града и шире.
					</p>

					<div class="image-container-1">
						{aboutImages.map((img) => (
							<img 
								class="image" 
								src={img.url} 
								alt={img.alt} 
								width={img.width} 
								height={img.height} 
								loading="lazy" 
							/>
						))}
					</div>
				</div>
			</section>

			<!-- Natura 2000 Section -->
			<section id="natura_2000">
				<div class="section-content">
					<h2>&quot;Натура 2000 ресурсни центар Србије&quot;</h2>
					<p>
						Друштво је члан националне мреже &quot;Натура 2000 ресурсни центар Србије&quot;, 
						и активно учествује у имплементацији концепта еколошке мреже НАТУРА 2000 у сарадњи 
						са државним органима и институцијама. Организовало је научно-стручно предавање на 
						тему порекла и настанка заразних вирусних болести у сарадњи са библиотеком у Краљеву 
						као и бројна друга предавања и промоције књига из области биологије, екологије и 
						заштите животне средине (&quot;Белоглави суп&quot;, &quot;Приручник о дневним лептирима&quot;, 
						књига &quot;Основи екологије&quot;). Научни и стручни сарадник Друштва је 
						Ветеринарски специјалистички институт Краљево.
					</p>

					<div class="image-container-1" style="justify-content: center;">
						<img 
							class="image3" 
							src="/Natura_2.jpg" 
							alt="Натура 2000 Србија центар" 
							width="1320" 
							height="579" 
							loading="lazy" 
						/>
					</div>
				</div>
			</section>

			<!-- Collaborators Section -->
			<section id="saradnici">
				<div class="section-content">
					<h2>Сарадници</h2>
					<p>
						Друштво је било носилац великог броја пројеката финансираних од стране Министарства 
						просвете и науке, односно Центра за промоцију науке, града Краљева, ЈП 
						&quot;Србијашуме&quot;, НП &quot;Ђердап&quot;, СРП &quot;Пештерско поље&quot;, 
						и других. Сарадници на пројектима су Еколошко истраживачко друштво &quot;Младен Караман&quot; 
						из Крагујевца, Институт за биологију и екологију ПМФ Крагујевац, Ветеринарски 
						специјалистички институт Краљево, Српско биолошко друштво &quot;Стеван Јаковљевић&quot; 
						и други. Чланови Друштва раде на програму истраживања биодиверзитета планина Гоч, 
						Чемерно, Голија, Столови, Жељин, НП Ђердап, Пештер, Лазарев кањон, и осталим.
					</p>

					<div class="image-container-2">
						{collaborators.map((partner) => (
							<div class="image2_container">
								<h4>{partner.caption}</h4>
								<a href={partner.link} target="_blank" rel="noopener noreferrer">
									<img 
										class="image2" 
										src={partner.url} 
										alt={partner.caption} 
										width={partner.width} 
										height={partner.height} 
										loading="lazy" 
									/>
								</a>
							</div>
						))}
					</div>
				</div>
			</section>

			<!-- Social Media Section -->
			<section id="drustvene_mreze">
				<div class="section-content">
					<div class="drustvene_mreze">
						<h2>Балкан на друштвеним мрежама</h2>
						
						<!-- YouTube Uploads Embed -->
						<div class="iframe-wrapper">
							<iframe 
								class="iframe" 
								src="https://www.youtube.com/embed/?listType=user_uploads&list=kapdbalkan" 
								title="Balkan YouTube Channel" 
								allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
								referrerpolicy="strict-origin-when-cross-origin" 
								allowfullscreen
							></iframe>
						</div>

						<!-- Facebook Page Embed -->
						<div class="fb-iframe-wrapper">
							<iframe 
								class="iframe" 
								src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fkapdbalkankv&tabs=photos&width=500&height=200&small_header=false&adapt_container_width=false&hide_cover=false&show_facepile=false&appId=250907958354610" 
								title="Balkan Facebook Page"
								allowfullscreen
							></iframe>
						</div>
					</div>
				</div>
			</section>

		</div>

		<!-- Footer Contact Information -->
		<div id="kontakt" class="main-contact-container">
			<div class="contact-container">
				<p>
					Телефон: <a href="tel:+381641688141">064 1688141</a>
				</p>
				<p>
					Електронска пошта: <a href="mailto:kapdbalkan@gmail.com">kapdbalkan@gmail.com</a>
				</p>
				<p>
					Адреса: Жичка 34, 36000 Краљево
				</p>
			</div>

			<!-- Copyright Footer -->
			<div class="footer-copyright">
				&copy; {new Date().getFullYear()} КАПД Балкан. Сва права задржана. Израда сајта: <a href="https://zigicode.com" target="_blank" rel="noopener noreferrer">Zigi Code</a>
			</div>

			<!-- Mobile Drawer Phone Widget -->
			<div class="floating-contact" id="floatingContact">
				<img 
					class="phone" 
					src="/phone.svg" 
					alt="Позовите нас" 
					width="512" 
					height="512" 
					id="phoneIcon" 
				/>
				<div>
					<a href="tel:+381641688141"><u>064 1688141</u></a>
				</div>
			</div>
		</div>

		<!-- Lightbox Gallery Modal -->
		<div id="lightbox" class="lightbox-modal" role="dialog" aria-label="Галерија слика" aria-hidden="true">
			<button class="lightbox-close" id="lightboxClose" aria-label="Затвори галерију">&times;</button>
			<button class="lightbox-arrow lightbox-arrow-left" id="lightboxPrev" aria-label="Претходна слика">&#10094;</button>
			<div class="lightbox-content-wrapper">
				<img id="lightboxImg" src="" alt="" class="lightbox-img" />
				<div id="lightboxCaption" class="lightbox-caption"></div>
			</div>
			<button class="lightbox-arrow lightbox-arrow-right" id="lightboxNext" aria-label="Следећа слика">&#10095;</button>
		</div>
	</main>
</Layout>

<!-- Client-side Interactive Animations Script -->
<script>
	// 3D Parallax forest movement based on cursor
	const hero = document.getElementById('heroBanner');
	if (hero && window.innerWidth > 768) {
		window.addEventListener('mousemove', (e) => {
			const x = (window.innerWidth / 2 - e.clientX) / 45;
			const y = (window.innerHeight / 2 - e.clientY) / 45;
			hero.style.backgroundPosition = `calc(50% + ${x}px) calc(50% + ${y}px)`;
		});
	}

	// Mobile Floating Contact Widget Drawer Toggle
	const floatingContact = document.getElementById('floatingContact');
	const phoneIcon = document.getElementById('phoneIcon');
	if (floatingContact && phoneIcon) {
		phoneIcon.addEventListener('click', (e) => {
			e.stopPropagation();
			floatingContact.classList.toggle('open');
		});

		// Auto-close widget when clicking anywhere else
		document.addEventListener('click', (e) => {
			if (e.target && !floatingContact.contains(e.target as Node)) {
				floatingContact.classList.remove('open');
			}
		});
	}

	// Gallery Lightbox Functionality
	const lightbox = document.getElementById('lightbox');
	const lightboxImg = document.getElementById('lightboxImg') as HTMLImageElement;
	const lightboxCaption = document.getElementById('lightboxCaption');
	const lightboxClose = document.getElementById('lightboxClose');
	const lightboxPrev = document.getElementById('lightboxPrev');
	const lightboxNext = document.getElementById('lightboxNext');

	if (lightbox && lightboxImg && lightboxCaption && lightboxClose && lightboxPrev && lightboxNext) {
		// Select only gallery-relevant pictures
		const images = Array.from(document.querySelectorAll('#o_nama .image, #natura_2000 .image3')) as HTMLImageElement[];
		let currentIndex = 0;

		const openLightbox = (index: number) => {
			currentIndex = index;
			const img = images[currentIndex];
			lightboxImg.src = img.src;
			lightboxImg.alt = img.alt;
			lightboxCaption.textContent = img.alt || '';
			lightbox.classList.add('active');
			lightbox.setAttribute('aria-hidden', 'false');
			document.body.style.overflow = 'hidden'; // Lock background scrolling
		};

		const closeLightbox = () => {
			lightbox.classList.remove('active');
			lightbox.setAttribute('aria-hidden', 'true');
			document.body.style.overflow = ''; // Unlock background scrolling
		};

		const showNext = () => {
			currentIndex = (currentIndex + 1) % images.length;
			openLightbox(currentIndex);
		};

		const showPrev = () => {
			currentIndex = (currentIndex - 1 + images.length) % images.length;
			openLightbox(currentIndex);
		};

		// Attach click handlers to active gallery images
		images.forEach((img, index) => {
			img.style.cursor = 'pointer';
			img.addEventListener('click', () => {
				openLightbox(index);
			});
		});

		// Control handlers
		lightboxClose.addEventListener('click', closeLightbox);
		
		// Close by clicking backdrop
		lightbox.addEventListener('click', (e) => {
			if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-content-wrapper')) {
				closeLightbox();
			}
		});

		lightboxNext.addEventListener('click', (e) => {
			e.stopPropagation();
			showNext();
		});

		lightboxPrev.addEventListener('click', (e) => {
			e.stopPropagation();
			showPrev();
		});

		// Keyboard event controls
		document.addEventListener('keydown', (e) => {
			if (!lightbox.classList.contains('active')) return;
			if (e.key === 'Escape') closeLightbox();
			if (e.key === 'ArrowRight') showNext();
			if (e.key === 'ArrowLeft') showPrev();
		});
	}
</script>
